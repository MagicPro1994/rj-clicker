<Window x:Class="RjClicker.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:validation="clr-namespace:RjClicker.App.Validation"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="RjClicker"
        Height="760"
        Width="1040"
        MinHeight="680"
        MinWidth="920"
        Background="#FFF4F2EA">
    <DockPanel LastChildFill="True" Margin="16">
        <Border DockPanel.Dock="Bottom"
                Margin="0,8,0,0"
                Padding="10"
                Background="#FFE7DCC8"
                CornerRadius="8">
            <DockPanel>
            <TextBlock Text="{Binding StartStopHotkeyDisplay, StringFormat=Hot Key: {0} (Start/Stop)}"
                           FontWeight="SemiBold"
                           Foreground="#FF4B3C2A"
                           DockPanel.Dock="Right" />
                <TextBlock Text="{Binding CurrentStatus}"
                           Foreground="#FF2A2A2A"
                           FontSize="13" />
            </DockPanel>
        </Border>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Padding="14"
                    Margin="0,0,0,8"
                    Background="#FFFDF8EE"
                    BorderBrush="#FFDBC9AA"
                    BorderThickness="1"
                    CornerRadius="10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                        <TextBlock Text="Mouse Button" FontWeight="SemiBold" Margin="0,0,0,4" />
                        <ComboBox ItemsSource="{Binding MouseButtons}"
                                  SelectedItem="{Binding SelectedMouseButton, Mode=TwoWay}"
                                  MinWidth="140" />
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="0,0,10,0">
                        <TextBlock Text="Press Type" FontWeight="SemiBold" Margin="0,0,0,4" />
                        <ComboBox ItemsSource="{Binding PressTypes}"
                                  SelectedItem="{Binding SelectedPressType, Mode=TwoWay}"
                                  MinWidth="140" />
                    </StackPanel>

                    <StackPanel Grid.Column="2" Margin="0,0,10,0">
                        <TextBlock Text="Click Mode" FontWeight="SemiBold" Margin="0,0,0,4" />
                        <ComboBox ItemsSource="{Binding ClickModes}"
                                  SelectedItem="{Binding SelectedClickMode, Mode=TwoWay}"
                                  MinWidth="140" />
                    </StackPanel>

                    <StackPanel Grid.Column="3">
                        <TextBlock Text="Delivery Mode" FontWeight="SemiBold" Margin="0,0,0,4" />
                        <ComboBox ItemsSource="{Binding DeliveryModes}"
                                  SelectedItem="{Binding SelectedDeliveryMode, Mode=TwoWay}"
                                  MinWidth="140" />
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2.3*" />
                    <ColumnDefinition Width="1.2*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Padding="14"
                        Margin="0,0,8,0"
                        Background="#FFFDF8EE"
                        BorderBrush="#FFDBC9AA"
                        BorderThickness="1"
                        CornerRadius="10">
                    <StackPanel>
                        <TextBlock Text="Interval"
                                   FontWeight="SemiBold"
                                   FontSize="14"
                                   Margin="0,0,0,8" />

                        <WrapPanel Margin="0,0,0,6" VerticalAlignment="Center">
                            <TextBox Width="44" Margin="0,0,4,0">
                                <TextBox.Text>
                                    <Binding Path="HoursPart" Mode="TwoWay" UpdateSourceTrigger="PropertyChanged" NotifyOnValidationError="True">
                                        <Binding.ValidationRules>
                                            <validation:NonNegativeIntegerValidationRule />
                                        </Binding.ValidationRules>
                                    </Binding>
                                </TextBox.Text>
                            </TextBox>
                            <TextBlock Text=":" Margin="0,0,4,0" VerticalAlignment="Center" />
                            <TextBox Width="44" Margin="0,0,4,0">
                                <TextBox.Text>
                                    <Binding Path="MinutesPart" Mode="TwoWay" UpdateSourceTrigger="PropertyChanged" NotifyOnValidationError="True">
                                        <Binding.ValidationRules>
                                            <validation:NonNegativeIntegerValidationRule />
                                        </Binding.ValidationRules>
                                    </Binding>
                                </TextBox.Text>
                            </TextBox>
                            <TextBlock Text=":" Margin="0,0,4,0" VerticalAlignment="Center" />
                            <TextBox Width="44" Margin="0,0,4,0">
                                <TextBox.Text>
                                    <Binding Path="SecondsPart" Mode="TwoWay" UpdateSourceTrigger="PropertyChanged" NotifyOnValidationError="True">
                                        <Binding.ValidationRules>
                                            <validation:NonNegativeIntegerValidationRule />
                                        </Binding.ValidationRules>
                                    </Binding>
                                </TextBox.Text>
                            </TextBox>
                            <TextBlock Text="." Margin="0,0,4,0" VerticalAlignment="Center" />
                            <TextBox Width="34" Margin="0,0,4,0">
                                <TextBox.Text>
                                    <Binding Path="TenthsPart" Mode="TwoWay" UpdateSourceTrigger="PropertyChanged" NotifyOnValidationError="True">
                                        <Binding.ValidationRules>
                                            <validation:NonNegativeIntegerValidationRule />
                                        </Binding.ValidationRules>
                                    </Binding>
                                </TextBox.Text>
                            </TextBox>
                            <TextBox Width="34" Margin="0,0,4,0">
                                <TextBox.Text>
                                    <Binding Path="HundredthsPart" Mode="TwoWay" UpdateSourceTrigger="PropertyChanged" NotifyOnValidationError="True">
                                        <Binding.ValidationRules>
                                            <validation:NonNegativeIntegerValidationRule />
                                        </Binding.ValidationRules>
                                    </Binding>
                                </TextBox.Text>
                            </TextBox>
                            <TextBox Width="34" Margin="0,0,8,0">
                                <TextBox.Text>
                                    <Binding Path="ThousandthsPart" Mode="TwoWay" UpdateSourceTrigger="PropertyChanged" NotifyOnValidationError="True">
                                        <Binding.ValidationRules>
                                            <validation:NonNegativeIntegerValidationRule />
                                        </Binding.ValidationRules>
                                    </Binding>
                                </TextBox.Text>
                            </TextBox>
                            <TextBlock Text="(H:MM:SS.hh)" VerticalAlignment="Center" Foreground="#FF5E5E5E" />
                        </WrapPanel>

                        <WrapPanel VerticalAlignment="Center" Margin="0,0,0,6">
                            <TextBlock Text="Manual ms:" VerticalAlignment="Center" Margin="0,0,8,0" />
                            <TextBox Width="120"
                                     Margin="0,0,10,0">
                                <TextBox.Text>
                                    <Binding Path="TotalIntervalMs" Mode="TwoWay" UpdateSourceTrigger="PropertyChanged" NotifyOnValidationError="True">
                                        <Binding.ValidationRules>
                                            <validation:NonNegativeIntegerValidationRule />
                                        </Binding.ValidationRules>
                                    </Binding>
                                </TextBox.Text>
                            </TextBox>
                            <TextBlock Text="{Binding TotalIntervalMs, StringFormat=Total: {0} ms}"
                                       VerticalAlignment="Center"
                                       FontWeight="SemiBold"
                                       Foreground="#FF4B3C2A" />
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1"
                        Padding="14"
                        Background="#FFFDF8EE"
                        BorderBrush="#FFDBC9AA"
                        BorderThickness="1"
                        CornerRadius="10">
                    <StackPanel>
                        <TextBlock Text="Counter" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,8" />
                        <CheckBox Content="Stop on count"
                                  IsChecked="{Binding UseCounter, Mode=TwoWay}"
                                  Margin="0,0,0,8" />
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Max clicks:" VerticalAlignment="Center" Margin="0,0,8,0" />
                            <TextBox Width="96"
                                     IsEnabled="{Binding UseCounter}"
                                     Text="{Binding MaxClicks, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <Border Grid.Row="2"
                    Padding="14"
                    Margin="0,0,0,8"
                    Background="#FFFDF8EE"
                    BorderBrush="#FFDBC9AA"
                    BorderThickness="1"
                    CornerRadius="10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.6*" />
                        <ColumnDefinition Width="1*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,8,0">
                        <TextBlock Text="Hotkey Configuration"
                                   FontWeight="SemiBold"
                                   FontSize="14"
                                   Margin="0,0,0,8" />

                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="180" />
                                <ColumnDefinition Width="150" />
                                <ColumnDefinition Width="150" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" Text="Start/Stop hotkey:" VerticalAlignment="Center" Margin="0,0,8,0" />
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding HotkeyModifiers}"
                                      SelectedItem="{Binding StartStopModifiers, Mode=TwoWay}"
                                      Margin="0,0,8,0" />
                            <ComboBox Grid.Column="2"
                                      ItemsSource="{Binding HotkeyKeys}"
                                      SelectedItem="{Binding StartStopKey, Mode=TwoWay}" />
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="180" />
                                <ColumnDefinition Width="150" />
                                <ColumnDefinition Width="150" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" Text="Record hotkey:" VerticalAlignment="Center" Margin="0,0,8,0" />
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding HotkeyModifiers}"
                                      SelectedItem="{Binding RecordModifiers, Mode=TwoWay}"
                                      Margin="0,0,8,0" />
                            <ComboBox Grid.Column="2"
                                      ItemsSource="{Binding HotkeyKeys}"
                                      SelectedItem="{Binding RecordKey, Mode=TwoWay}" />
                        </Grid>
                    </StackPanel>

                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Options" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,8" />
                        <CheckBox Content="Smart Click" IsChecked="{Binding UseSmartClick, Mode=TwoWay}" Margin="0,0,0,6" />
                        <CheckBox Content="Freeze Pointer" IsChecked="{Binding FreezePointer, Mode=TwoWay}" Margin="0,0,0,6" />
                        <CheckBox Content="Keep on Top" IsChecked="{Binding KeepOnTop, Mode=TwoWay}" Margin="0,0,0,10" />
                        <Button Content="{Binding HideShowWindowText}"
                                Command="{Binding HideShowWindowCommand}"
                                Width="90"
                                HorizontalAlignment="Left"
                                Padding="10,4" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="3"
                    Padding="14"
                    Margin="0,0,0,8"
                    Background="#FFFDF8EE"
                    BorderBrush="#FFDBC9AA"
                    BorderThickness="1"
                    CornerRadius="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0" Margin="0,0,0,10">
                        <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                            <Button Content="Add Point" Command="{Binding AddPoint}" Margin="0,0,8,0" Padding="10,4" />
                            <Button Content="Record Point" Command="{Binding RecordPoint}" Padding="10,4" />
                        </StackPanel>
                        <TextBlock Text="Point Targets"
                                   VerticalAlignment="Center"
                                   FontWeight="SemiBold"
                                   FontSize="14" />
                    </DockPanel>

                    <DataGrid Grid.Row="1"
                              AutoGenerateColumns="False"
                              ItemsSource="{Binding PointTargets}"
                              CanUserAddRows="False"
                              HeadersVisibility="Column"
                              IsReadOnly="False"
                              GridLinesVisibility="Horizontal">
                        <DataGrid.Columns>
                            <DataGridComboBoxColumn Header="Type"
                                                    Width="170"
                                                    SelectedItemBinding="{Binding TargetType, Mode=TwoWay}"
                                                    ItemsSource="{Binding DataContext.TargetTypes, RelativeSource={RelativeSource AncestorType=Window}}" />
                            <DataGridTextColumn Header="X" Binding="{Binding X, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="90" />
                            <DataGridTextColumn Header="Y" Binding="{Binding Y, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="90" />
                            <DataGridTextColumn Header="Window ID" Binding="{Binding WindowId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="140" />
                            <DataGridTextColumn Header="Display" Binding="{Binding DisplayText}" Width="*" IsReadOnly="True" />
                            <DataGridTemplateColumn Header="Action" Width="180">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <Button Content="▲"
                                                    Command="{Binding DataContext.MovePointUp, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"
                                                    Margin="0,0,4,0"
                                                    Padding="6,2" />
                                            <Button Content="▼"
                                                    Command="{Binding DataContext.MovePointDown, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"
                                                    Margin="0,0,4,0"
                                                    Padding="6,2" />
                                            <Button Content="Delete" Command="{Binding Delete}" Padding="8,2" />
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
                <TextBlock Text="Clicks:" VerticalAlignment="Center" Margin="0,0,8,0" />
                <TextBlock Text="{Binding ClickCount}" VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,24,0" />
                <Button Content="Start"
                        Command="{Binding StartClickSession}"
                        Padding="14,6"
                        Margin="0,0,8,0" />
                <Button Content="Stop"
                        Command="{Binding StopClickSession}"
                        Padding="14,6" />
            </StackPanel>
        </Grid>
    </DockPanel>
</Window>
